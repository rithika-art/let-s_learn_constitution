@startuml
left to right direction
skinparam packageStyle rectangle

actor Student
actor Admin

rectangle "Constitution Learning Platform" {
  usecase "Register" as UC1
  usecase "Login" as UC2
  usecase "View Constitution Modules" as UC3
  usecase "Take Quiz" as UC4
  usecase "View Progress" as UC5
  usecase "Manage Modules" as UC6
  usecase "Manage Quiz Questions" as UC7
  usecase "View Student Progress" as UC8
}

Student --> UC1
Student --> UC2
Student --> UC3
Student --> UC4
Student --> UC5

Admin --> UC2
Admin --> UC6
Admin --> UC7
Admin --> UC8

@enduml
