@startuml
left to right direction
skinparam packageStyle rectangle

actor Student as student

rectangle "Student Portal" {
  usecase "Register Account" as UC1
  usecase "Login to System" as UC2
  usecase "View Constitution Modules" as UC3
  usecase "Read Module Content" as UC4
  usecase "Take Quiz" as UC5
  usecase "View My Progress" as UC6
  usecase "View Scores" as UC7
}

student --> UC1
student --> UC2
UC2 ..> UC3 : <<include>>
UC3 --> UC4
UC3 --> UC5
student --> UC6
student --> UC7

@enduml
